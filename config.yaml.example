nim:
  api_key: "YOUR_NIM_API_KEY"
  endpoint: "https://integrate.api.nvidia.com/v1/chat/completions"
  model: "meta/llama-3.2-11b-vision-instruct"
  explain_model: "mistralai/mistral-small-24b-instruct"
  retry_wait: 3.0

groq:
  api_key: "YOUR_GROQ_API_KEY"
  model: "llama-3.3-70b-versatile"

camera:
  index: 0
  capture_interval: 10.0
  change_threshold: 0.05

student:
  grade_level: 10

tts:
  model: "sapi"

stt:
  model: "medium"   # options: tiny, base, small, medium, large

hotkey: "space"

logging:
  level: "DEBUG"
  log_file: "board_reader.log"

rl:
  enabled: true
  profile_path: "student_profile.json"
